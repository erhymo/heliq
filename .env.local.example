# Heliq local/dev configuration. Do not commit real secrets.
HELIQ_ADMIN_PASSWORD=change-me
HELIQ_SESSION_SECRET=replace-with-a-long-random-string
HELIQ_PIN_PEPPER=replace-with-another-long-random-string

# Firebase Admin SDK. Use either these three values in Vercel,
# or GOOGLE_APPLICATION_CREDENTIALS locally.
FIREBASE_PROJECT_ID=heliq
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"
